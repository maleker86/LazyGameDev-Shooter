pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
-- clear screen
 cls(1)

 -- variables
 shipx = 64
 shipy = 80

 shipspdx=0
 shipspdy=0
 
 speed=3
 bullspeed=5

 bulletx = -10
 bullety = shipy-15
-- ball = spr(1)
-- string = spr(2)
-- enemy_1 = spr(3)
 box1x = 8
 box1y = 90
 box2x = 120
 box2y = 120
--	col = 3
end

function _update()
-- controls
 if btn(➡️) then
  shipx+=speed
	end
	
 if btn(⬅️) then
  shipx-=speed
	end
	
 if btn(⬆️) then
  shipy-=speed
	end
	
 if btn(⬇️) then
  shipy+=speed
	end
	
 if btnp(❎) then
  print("░")
  sfx(0)
  bulletx=shipx
  bullety=shipy-bullspeed
	end

-- moving the ship
 shipx=shipx+shipspdx
 shipy=shipy+shipspdy

-- move the bullet
 bullety=bullety-4

-- keep it on screen
	if shipx < 10 then
		shipx = 10
	elseif shipx > 110 then
		shipx = 110
	elseif shipy > box2y-10 then
		shipy = box2y-10
	elseif shipy < box1x then
		shipy = box1x
	end

end

function _draw() 
 cls(1)
-- spr(0,y1)
 rectfill(box1x,box1y,box2x,box2y,15)
	spr(1,shipx,shipy)
	spr(2,bulletx,bullety)
--	circ(25,25,50,)

end
